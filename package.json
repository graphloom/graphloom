{
  "name": "graphloom-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint && node tools/check-boundaries.mjs && node tools/check-docs.mjs",
    "typecheck": "tsc -b",
    "e2e": "playwright test",
    "e2e:a11y": "playwright test e2e/a11y.spec.ts",
    "bench": "pnpm --filter @graphloom/rendering exec vitest run src/perf.smoke.test.ts",
    "pkgcheck": "node tools/check-packages.mjs",
    "format": "prettier --write .",
    "prepare": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "2.6.3",
    "@angular/build": "22.0.5",
    "@angular/common": "22.0.6",
    "@angular/compiler": "22.0.6",
    "@angular/compiler-cli": "22.0.6",
    "@angular/core": "22.0.6",
    "@angular/platform-browser": "22.0.6",
    "@angular/platform-server": "22.0.6",
    "@arethetypeswrong/cli": "^0.18.4",
    "@axe-core/playwright": "^4.12.1",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@graphloom/core": "workspace:*",
    "@playwright/test": "^1.61.1",
    "@types/d3-quadtree": "^3.0.6",
    "@types/node": "^24.13.2",
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "fast-check": "^4.8.0",
    "jsdom": "^29.1.1",
    "ng-packagr": "22.0.1",
    "nx": "^23.0.1",
    "prettier": "^3.9.4",
    "publint": "^0.3.21",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
