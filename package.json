{
  "name": "graphloom-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint && node tools/check-boundaries.mjs && node tools/check-docs.mjs",
    "typecheck": "tsc -b",
    "e2e": "playwright test",
    "pkgcheck": "node tools/check-packages.mjs",
    "format": "prettier --write .",
    "prepare": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@graphloom/core": "workspace:*",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.2",
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "nx": "^23.0.1",
    "prettier": "^3.9.4",
    "publint": "^0.3.21",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
