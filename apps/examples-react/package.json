{
  "name": "examples-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "dependencies": {
    "@graphloom/core": "workspace:*",
    "@graphloom/interaction": "workspace:*",
    "@graphloom/react": "workspace:*"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --ssr src/main.server.tsx --outDir dist/server && node prerender.mjs",
