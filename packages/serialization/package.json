{
  "name": "@graphloom/serialization",
  "version": "0.0.1",
  "description": "GraphLoom serialization package",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/graphloom/graphloom.git",
    "directory": "packages/serialization"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean",
    "test": "vitest run --coverage",
    "lint": "eslint src",
    "typecheck": "tsc -b"
  }
}
